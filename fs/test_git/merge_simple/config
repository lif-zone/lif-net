[core]
	repositoryformatversion = 0
	filemode = false
	bare = false
	logallrefupdates = true
	symlinks = false
	ignorecase = true

[remote "origin"]
	fetch = +refs/heads/*:refs/remotes/origin/*
	url = https://github.com/lif-zone/test_merge_simple
[branch "main"]
	merge = refs/heads/main
	remote = origin
[branch "branch1"]
	merge = refs/heads/branch1
	remote = origin