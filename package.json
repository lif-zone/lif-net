    "eslint-plugin-react": "^7.27.1",
    "evil-dns": "0.2.0",
    "mocha": "9.1.3",
    "ping": "0.4.1",
    "sinon": "1.17.6",
    "when": "2.2.1"
  },
  "browserify": {
    "transform": [
      [
        "babelify",
        {
          "presets": [
            "@babel/env"
          ],
          "plugins": [
            "@babel/plugin-transform-runtime",
            "@babel/plugin-transform-react-jsx"
          ]
        }
      ]
    ]
  }
